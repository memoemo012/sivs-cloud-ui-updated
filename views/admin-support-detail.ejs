<%- include('partials/header', { title: t('supportDetail') }) %><section class="panel"><div class="panel-head"><h2><%= t('supportDetail') %> #<%= ticket.id %></h2><a class="btn-soft" href="/admin/support"><%= t('back') %></a></div><div class="detail-grid"><div class="detail-item"><strong><%= t('sender') %></strong><div><%= ticket.requester_name %></div></div><div class="detail-item"><strong><%= t('contactUser') %></strong><div><%= ticket.requester_contact || '-' %></div></div><div class="detail-item"><strong><%= t('subject') %></strong><div><%= ticket.subject || '-' %></div></div><div class="detail-item"><strong><%= t('status') %></strong><div><%= mapStatus(ticket.status) %></div></div></div><article class="message-box"><%= ticket.message %></article><form method="post" class="form-grid"><select name="status"><option value="NEW" <%= ticket.status==='NEW'?'selected':'' %>><%= t('new') %></option><option value="IN_PROGRESS" <%= ticket.status==='IN_PROGRESS'?'selected':'' %>><%= t('inProgress') %></option><option value="SOLVED" <%= ticket.status==='SOLVED'?'selected':'' %>><%= t('solved') %></option></select><textarea name="admin_reply" placeholder="<%= t('reply') %>"><%= ticket.admin_reply || '' %></textarea><button class="btn-gradient" type="submit"><%= t('saveChanges') %></button></form></section><%- include('partials/footer') %>