<%- include('partials/header', { title: t('myDevices') }) %><div class="mobile-shell"><section class="panel"><div class="panel-head"><h2><%= t('devicesManagement') %></h2></div><div class="list-grid"><% devices.forEach(device=>{ %><div class="device-card"><div><strong><%= device.name %></strong><p><%= device.location %></p><span class="mini"><%= device.device_code %></span></div><div><span class="badge <%= device.is_online?'on':'off' %>"><%= device.is_online ? t('online') : t('offline') %></span><div class="spacer"></div><span class="badge <%= device.is_active?'solved':'progress' %>"><%= device.is_active ? t('active') : t('suspended') %></span></div></div><% }) %></div></section></div><%- include('partials/footer') %>