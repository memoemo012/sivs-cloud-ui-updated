<%- include('partials/header', { title: t('settings') }) %>
<div class="mobile-shell app-mobile-shell">
  <section class="settings-mobile user-settings-screen">
    <div class="settings-card card-like">
      <button type="button" class="settings-row-button compact-row" id="openUserPasswordModal">
        <div class="settings-row-arrow"><%= dir === 'rtl' ? '›' : '‹' %></div>
        <div class="settings-row-content center-text">
          <strong><%= t('changePassword') %></strong>
          <span><%= lang === 'ar' ? 'تحديث كلمة مرور الحساب' : 'Update account password' %></span>
        </div>
        <div class="settings-row-icon">🔐</div>
      </button>
    </div>

    <form method="post" action="/user/settings" class="settings-card card-like notify-main-card autosave-form" id="notifyForm">
      <div class="section-title"><%= t('notificationMethod') %></div>

      <div class="notify-option-grid">
        <label class="notify-option-row">
          <input type="radio" name="notification_mode" value="sound" <%= (user.notification_mode || 'sound') === 'sound' ? 'checked' : '' %> />
          <span class="radio-ui"></span>
          <span class="notify-option-text"><%= t('soundLabel') %></span>
          <span class="choice-icon boxed">🔊</span>
        </label>
        <label class="notify-option-row">
          <input type="radio" name="notification_mode" value="vibration" <%= user.notification_mode === 'vibration' ? 'checked' : '' %> />
          <span class="radio-ui"></span>
          <span class="notify-option-text"><%= t('vibrationLabel') %></span>
          <span class="choice-icon boxed">📳</span>
        </label>
        <label class="notify-option-row">
          <input type="radio" name="notification_mode" value="silent" <%= user.notification_mode === 'silent' ? 'checked' : '' %> />
          <span class="radio-ui"></span>
          <span class="notify-option-text"><%= t('silentLabel') %></span>
          <span class="choice-icon boxed">🔕</span>
        </label>
      </div>

      <label class="toggle-list-card">
        <span class="ios-switch">
          <input type="checkbox" name="push_enabled" value="1" <%= user.push_enabled ? 'checked' : '' %> />
          <span class="slider"></span>
        </span>
        <span class="tile-text middle">
          <strong><%= t('verificationFailureAlert') %></strong>
          <small><%= t('onFailureOfVerification') %></small>
        </span>
        <span class="choice-icon boxed">✖</span>
      </label>

      <label class="toggle-list-card">
        <span class="ios-switch">
          <input type="checkbox" name="email_enabled" value="1" <%= user.email_enabled ? 'checked' : '' %> />
          <span class="slider"></span>
        </span>
        <span class="tile-text middle">
          <strong><%= t('abnormalAttemptAlert') %></strong>
          <small><%= t('onAbnormalAttempt') %></small>
        </span>
        <span class="choice-icon boxed">⚠</span>
      </label>

      <label class="toggle-list-card">
        <span class="ios-switch">
          <input type="checkbox" name="important_only" value="1" <%= user.important_only ? 'checked' : '' %> />
          <span class="slider"></span>
        </span>
        <span class="tile-text middle">
          <strong><%= t('successfulLoginAlert') %></strong>
          <small><%= t('onSuccessfulLogin') %></small>
        </span>
        <span class="choice-icon boxed">✓</span>
      </label>

      <input type="hidden" name="biometric_enabled" value="<%= user.biometric_enabled ? 1 : 0 %>" />
    </form>
  </section>
</div>

<div class="modal-overlay" id="userPasswordModal" hidden>
  <div class="modal-sheet">
    <div class="modal-handle"></div>
    <button type="button" class="modal-close-x" id="closeUserPasswordModal">×</button>
    <h3><%= t('changePassword') %></h3>
    <form method="post" action="/user/change-password" class="password-form">
      <input type="password" name="current_password" placeholder="<%= lang === 'ar' ? 'كلمة المرور الحالية' : 'Current password' %>" required />
      <input type="password" name="new_password" placeholder="<%= lang === 'ar' ? 'كلمة المرور الجديدة' : 'New password' %>" required />
      <input type="password" name="confirm_password" placeholder="<%= lang === 'ar' ? 'تأكيد كلمة المرور الجديدة' : 'Confirm new password' %>" required />
      <button type="submit" class="btn-gradient full"><%= t('saveChanges') %></button>
      <button type="button" class="btn-soft modal-cancel" id="cancelUserPasswordModal"><%= t('cancelAction') %></button>
    </form>
  </div>
</div>

<script>
  const userModal = document.getElementById('userPasswordModal');
  const userOpenBtn = document.getElementById('openUserPasswordModal');
  const userCloseBtn = document.getElementById('closeUserPasswordModal');
  const userCancelBtn = document.getElementById('cancelUserPasswordModal');
  function closeUserModal(){ userModal.hidden = true; }
  userOpenBtn?.addEventListener('click', () => userModal.hidden = false);
  userCloseBtn?.addEventListener('click', closeUserModal);
  userCancelBtn?.addEventListener('click', closeUserModal);
  userModal?.addEventListener('click', (e) => { if (e.target === userModal) closeUserModal(); });

  document.querySelectorAll('.autosave-form').forEach((form) => {
    form.querySelectorAll('input, select, textarea').forEach((field) => {
      field.addEventListener('change', () => form.submit());
    });
  });
</script>
<%- include('partials/footer') %>
