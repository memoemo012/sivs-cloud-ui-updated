<%- include('partials/header', { title: t('details') }) %><section class="panel"><div class="panel-head"><h2><%= t('accessLogs') %> - <%= log.attempt_code %></h2><a class="btn-soft" href="/admin/logs"><%= t('back') %></a></div><div class="detail-grid"><div class="detail-item"><strong><%= t('sender') %></strong><div><%= log.user_name %></div></div><div class="detail-item"><strong><%= t('deviceName') %></strong><div><%= log.device_name %></div></div><div class="detail-item"><strong><%= t('status') %></strong><div><%= log.result %></div></div><div class="detail-item"><strong><%= t('createdAt') %></strong><div><%= log.created_at %></div></div></div><div class="panel"><h3><%= t('issueDetails') %></h3><div class="summary-list"><div class="summary-item"><span><%= t('faceId') %></span><strong><%= log.face_id %></strong></div><div class="summary-item"><span><%= t('cmdId') %></span><strong><%= log.cmd_id %></strong></div><div class="summary-item"><span>Face</span><strong><%= log.face_ok ? '✓' : '✕' %></strong></div><div class="summary-item"><span>Voice</span><strong><%= log.voice_ok ? '✓' : '✕' %></strong></div></div><article class="message-box"><%= log.reason %></article></div></section><%- include('partials/footer') %>