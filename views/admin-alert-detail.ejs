<%- include('partials/header', { title: t('details') }) %><section class="panel"><div class="panel-head"><h2><%= alert.title %></h2><a class="btn-soft" href="/admin/alerts"><%= t('back') %></a></div><div class="detail-grid"><div class="detail-item"><strong><%= t('sender') %></strong><div><%= alert.user_name || '-' %></div></div><div class="detail-item"><strong><%= t('deviceName') %></strong><div><%= alert.device_name %></div></div><div class="detail-item"><strong><%= t('status') %></strong><div><%= mapStatus(alert.status) %></div></div><div class="detail-item"><strong><%= t('createdAt') %></strong><div><%= alert.created_at %></div></div></div><article class="message-box"><%= alert.details || alert.subtitle %></article><form method="post" class="form-grid"><select name="status"><option value="NEW" <%= alert.status==='NEW'?'selected':'' %>><%= t('new') %></option><option value="IN_PROGRESS" <%= alert.status==='IN_PROGRESS'?'selected':'' %>><%= t('inProgress') %></option><option value="SOLVED" <%= alert.status==='SOLVED'?'selected':'' %>><%= t('solved') %></option></select><textarea name="admin_notes" placeholder="<%= t('notes') %>"><%= alert.admin_notes || '' %></textarea><button class="btn-gradient" type="submit"><%= t('saveChanges') %></button></form></section><%- include('partials/footer') %>